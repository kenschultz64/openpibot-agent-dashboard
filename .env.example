# OpenPiBot Dashboard environment
# Copy this to .env and fill in your values

# Dashboard bind address (0.0.0.0 for LAN/Tailscale, 127.0.0.1 for local only)
OPENPIBOT_DASHBOARD_HOST=0.0.0.0

# Dashboard port
OPENPIBOT_DASHBOARD_PORT=8766

# Polling interval in seconds
OPENPIBOT_DASHBOARD_POLL_INTERVAL=3

# Optional: session directory override
# OPENPIBOT_DASHBOARD_SESSION_DIR=/path/to/sessions

# Optional: config file override
# OPENPIBOT_DASHBOARD_CONFIG=/path/to/endpoints.json

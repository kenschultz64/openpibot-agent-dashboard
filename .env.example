# OpenPiBot Dashboard environment
# Copy this to .env and fill in your values
# chmod 600 .env

# ── Authentication (required for production) ──
OPENPIBOT_DASHBOARD_USER=admin
OPENPIBOT_DASHBOARD_PASS=strong-password-here

# ── Network ──
OPENPIBOT_DASHBOARD_HOST=0.0.0.0
OPENPIBOT_DASHBOARD_PORT=8766

# ── Polling ──
OPENPIBOT_DASHBOARD_POLL_INTERVAL=3
OPENPIBOT_DASHBOARD_TIMEOUT=5

# ── Rate limiting (optional) ──
# OPENPIBOT_DASHBOARD_RATE_CHAT=60
# OPENPIBOT_DASHBOARD_RATE_AGENT=10

# ── Logs (optional) ──
# OPENPIBOT_DASHBOARD_LOG_DIR=/path/to/logs
# OPENPIBOT_DASHBOARD_LOG_MAX_BYTES=10485760

# ── Sessions & config (optional) ──
# OPENPIBOT_DASHBOARD_SESSION_DIR=/path/to/sessions
# OPENPIBOT_DASHBOARD_CONFIG=/path/to/endpoints.json
